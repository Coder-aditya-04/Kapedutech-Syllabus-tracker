# Supabase — get from https://supabase.com/dashboard/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (Supabase handles this — configure in Supabase Auth settings)
# No need to set GOOGLE_CLIENT_ID/SECRET here; configure them in Supabase dashboard
# under Authentication > Providers > Google
